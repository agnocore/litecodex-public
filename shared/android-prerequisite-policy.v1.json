{
  "version": "v1.android-prerequisite-policy",
  "required_runtime_tools": [
    "java",
    "javac"
  ],
  "required_build_chain": [
    "gradle_or_gradlew",
    "sdkmanager",
    "adb"
  ],
  "required_sdk_components": [
    "cmdline-tools;latest",
    "platform-tools",
    "build-tools;34.0.0",
    "platforms;android-34"
  ],
  "emulator_policy": {
    "required_for_build_preflight": false,
    "required_for_device_verify": true,
    "deferred_status": "deferred_non_blocking"
  },
  "flutter_android_policy": {
    "status_if_missing": "deferred_non_blocking",
    "block_android_native_lane": false
  },
  "final_status": "enabled"
}
