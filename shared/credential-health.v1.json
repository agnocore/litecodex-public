{
  "version": "v1.credential-health.multi-provider",
  "provider": "openai | tavily | exa | firecrawl",
  "source": "byo_binding | .env",
  "source_scope": "browser_profile_scope | machine_scope | session_scope | local_process_memory",
  "grant_state": "bound | granted | degraded | unbound | deleted",
  "last_verified_at": "ISO-8601 | null",
  "health_status": "healthy | unhealthy | unavailable",
  "failure_reason": "string | null",
  "ambiguity_allowed": false
}
